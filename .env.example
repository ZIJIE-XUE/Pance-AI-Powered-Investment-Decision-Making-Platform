# AI Robo Advisor - Environment Configuration
# Copy this file to .env and fill in your values

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# --- Database ---
# SQLite (development default):
DATABASE_URL=sqlite+aiosqlite:///./robo_advisor.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/robo_advisor

# --- Redis (optional, falls back to diskcache if empty) ---
# REDIS_URL=redis://redis:6379/0

# --- Cache TTL (seconds) ---
CACHE_DEFAULT_TTL_SECONDS=3600
ADVISOR_CACHE_TTL_SECONDS=86400

# --- Report Storage ---
REPORT_STORAGE=local
REPORT_OUTPUT_DIR=reports_output

# --- Simulation Defaults ---
DEFAULT_NUM_PATHS=10000
DEFAULT_RISK_FREE_RATE=0.03

# --- Logging ---
LOG_LEVEL=INFO
